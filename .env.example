# Опционально, но рекомендуется: официальный Steam Web API ключ для
# получения матчей напрямую "из доты" (Valve GetMatchHistory), а не через
# производный индекс OpenDota. Получить бесплатно на своём Steam-аккаунте:
# https://steamcommunity.com/dev/apikey
#
# Скопируйте этот файл в .env и впишите свой ключ:
STEAM_API_KEY=

# Необязательно: переопределить путь к БД и league_id.
# TOURNAMENT_DB=tournament.db
# LEAGUE_ID=19924

# Необязательно: id турнира на mixer-cup.gg (используется, чтобы подтянуть
# реальные названия команд и актуальные ники из ростера). Без этого
# приложение само найдёт текущий активный турнир через API mixer-cup.gg.
# MIXER_TOURNAMENT_ID=26
